    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/node": "^22.0.0",
    "zod": "^3.23.0"
  }
}
