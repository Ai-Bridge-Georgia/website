{
  "name": "ai-bridge-georgia-os",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/engines/*",
    "packages/plugins/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/aibridgegeorgia",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "tsc --noEmit",
    "compile": "npx tsx packages/compiler/cli.ts",
    "validate": "npx tsx packages/validator/cli.ts",
    "evolve": "npx tsx packages/evolution/cli.ts",
    "enforce": "npx tsx packages/enforcement/test.ts",
    "design-compile": "npx tsx packages/design-compiler/cli.ts",
    "review-ui": "npx tsx packages/ui-pipeline/cli.ts"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsx": "^4.22.4",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "zod": "^3.23.0"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
