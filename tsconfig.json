{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@aibg/core": ["packages/core"],
      "@aibg/core/*": ["packages/core/*"],
      "@aibg/ui": ["packages/ui"],
      "@aibg/ui/*": ["packages/ui/*"],
      "@aibg/config": ["packages/config"],
      "@aibg/config/*": ["packages/config/*"],
      "@aibg/plugin-restaurant": ["packages/plugins/restaurant"],
      "@aibg/plugin-hotel": ["packages/plugins/hotel"],
      "@aibg/plugin-saas": ["packages/plugins/saas"],
      "@aibg/engine-form": ["packages/engines/form"],
      "@aibg/engine-dashboard": ["packages/engines/dashboard"],
      "@aibg/engine-notification": ["packages/engines/notification"],
      "@aibg/engine-workflow": ["packages/engines/workflow"],
      "@aibg/engine-permission": ["packages/engines/permission"],
      "@aibg/engine-rule": ["packages/engines/rule"],
      "@aibg/engine-search": ["packages/engines/search"],
      "@aibg/engine-import-export": ["packages/engines/import-export"],
      "@aibg/engine-audit": ["packages/engines/audit"],
      "@aibg/engine-scheduling": ["packages/engines/scheduling"],
      "@aibg/engine-report": ["packages/engines/report"],
      "@aibg/engine-ai": ["packages/engines/ai"],
      "@aibg/engine-integration": ["packages/engines/integration"],
      "@aibg/engine-plugin": ["packages/engines/plugin"]
    }
  },
  "include": ["packages/**/*", "apps/**/*"],
  "exclude": ["node_modules", ".next", "dist", "build"]
}
